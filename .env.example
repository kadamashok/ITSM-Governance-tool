APP_NAME=ITSM Governance API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8050
LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:5178,http://127.0.0.1:5178

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=itsm_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/itsm_db

SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your_password
SERVICENOW_ENCRYPTION_KEY=change_this_to_a_strong_secret
SERVICENOW_OAUTH_REDIRECT_URI=http://127.0.0.1:8050/auth/callback
FRONTEND_BASE_URL=http://127.0.0.1:5178
SERVICENOW_TIMEOUT_SECONDS=30
SERVICENOW_PAGE_SIZE=100
